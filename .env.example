# ── Orchestrator secrets ──────────────────────────────────────────
# The writer LLM key. Set whichever matches `llm.apiKeyEnv` in src/site.config.ts.
# Default is Google Gemini free tier (~1,500 req/day → https://aistudio.google.com/apikey).
GEMINI_API_KEY=
# Alternatives (set the matching one in site.config.ts to use): Groq
# (https://console.groq.com/keys) or OpenRouter (https://openrouter.ai/keys).
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Brave Search API (free tier: 2000 queries/mo) → https://api.search.brave.com/
# Optional — the pipeline skips it when unset.
BRAVE_API_KEY=

# Pexels API (free) → https://www.pexels.com/api/ — only needed when
# site.config.ts has imageProvider: 'pexels' ('openverse' is keyless).
PEXELS_API_KEY=

# Reddit API (free) — create a "script" app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# GitHub — a fine-grained PAT with Contents: Read/Write on the blog repo
GITHUB_TOKEN=
GITHUB_OWNER=your-gh-username
GITHUB_REPO=trendblog
GITHUB_BRANCH=main

# Secret the cron invoker must send as `Authorization: Bearer …`
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ── Syndication (optional) — auto-post each new article ───────────
# Any platform left blank is skipped. Configured ones are posted to after a
# successful run, with a link back to the canonical post.
# Bluesky: your handle + an app password (Settings → App passwords)
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=
# Mastodon: instance base URL (e.g. https://mastodon.social) + access token
# (Preferences → Development → New application)
MASTODON_INSTANCE_URL=
MASTODON_ACCESS_TOKEN=
# Telegram: broadcast each new post to a channel — strong fit for a movies
# audience (movie-news channels are huge there) and dead-simple to set up.
# Create a bot via @BotFather for the token, add it to your channel as an admin,
# and set the channel's @username (or numeric -100… id) as the chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# DEV.to: developer-audience platform — OFF by default for this movies niche
# (wrong readers). Leave blank unless you specifically want dev cross-posts.
DEVTO_API_KEY=

# ── Newsletter (optional) — footer signup form + weekly digest ────
# Provider for the signup form and the weekly digest workflow.
NEWSLETTER_PROVIDER=buttondown
# Buttondown API key (Settings → API) — required for subscribe + digest to work
BUTTONDOWN_API_KEY=
# Optional: digest look-back window in days (defaults to 7)
NEWSLETTER_WINDOW_DAYS=

# ── Ads (optional) — Google AdSense ───────────────────────────────
# Your AdSense publisher id, e.g. ca-pub-1234567890123456. When set, the
# AdSense script loads, /ads.txt is served, and ad slots render. Leave blank
# to keep the site ad-free.
NEXT_PUBLIC_ADSENSE_CLIENT=
# Ad unit slot ids (create the units in AdSense → Ads → By ad unit).
# Each slot renders only when its id is set; leave any blank to omit that unit.
#   ARTICLE_TOP — in-article (fluid) unit after the lead + takeaway callout
#   ARTICLE_MID — in-article (fluid) unit before "How to think about it"
#   IN_ARTICLE  — in-article (fluid) unit after the post body (below the FAQ)
#   LISTING     — display unit on the homepage between lead story and grid
#   FOOTER      — display unit site-wide above the footer
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE_TOP=
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE_MID=
NEXT_PUBLIC_ADSENSE_SLOT_IN_ARTICLE=
NEXT_PUBLIC_ADSENSE_SLOT_LISTING=
NEXT_PUBLIC_ADSENSE_SLOT_FOOTER=

# ── Affiliate (optional) — "Where to watch" rails on film posts ───
# Render earning links in the where-to-watch box on reviews + film posts.
# Any left blank is simply hidden; the non-earning JustWatch/provider links
# still render. A disclosure auto-appears whenever an earning link is shown.
# Amazon Associates tag (e.g. yoursite-20) → https://affiliate-program.amazon.com
# Powers both "Rent or buy on Amazon" (Prime Video) and "Own it on Blu-ray / 4K"
# (physical media) links on titled watch rails.
NEXT_PUBLIC_AMAZON_ASSOC_TAG=
# VPN affiliate (high payout for region-locked-streaming intent). Set the full
# affiliate URL and the display name shown in the CTA.
NEXT_PUBLIC_VPN_AFFILIATE_URL=
NEXT_PUBLIC_VPN_AFFILIATE_NAME=

# ── Optional ──────────────────────────────────────────────────────
# Your deployed URL (used for sitemap, RSS feed, OG tags)
NEXT_PUBLIC_SITE_URL=https://your-site.pages.dev
# Comma-separated YouTube channel IDs to pull transcripts from
YOUTUBE_CHANNELS=
# Comma-separated extra RSS feeds
EXTRA_FEEDS=

# ── Reviews layer (cinema reviews + release rails) ────────────────
# TMDB (The Movie Database) — free API key. Powers film facts, posters, cast,
# release dates, and "now playing / upcoming". Create a v3 API key at
# https://www.themoviedb.org/settings/api . Unset = review generation and the
# release rails are skipped (the news pipeline is unaffected).
TMDB_API_KEY=
# Optional: ElevenLabs API key for AI audio narration of reviews.
# Unset = no narration. https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# ── TinaCMS (only if you enable the hosted editor) ────────────────
# Leave these blank for self-hosted mode (local filesystem editing)
# The build script will automatically set placeholder values if needed
NEXT_PUBLIC_TINA_CLIENT_ID=
TINA_TOKEN=
